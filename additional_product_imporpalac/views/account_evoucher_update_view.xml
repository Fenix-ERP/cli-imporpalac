<?xml version='1.0' encoding='utf-8' ?>
<odoo>
    <!-- Form View -->
    <record id="account_evoucher_upodate_form_view" model="ir.ui.view">
        <field name="name">account.evoucher.update.form.view</field>
        <field name="model">account.evoucher</field>
        <field
            name="inherit_id"
            ref="l10n_ec_purchase_reception.account_evoucher_form_view"
        />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='estab']" position="after">
                <field name="product_type_selection" string="Product Type" />
            </xpath>
            <xpath expr="// button[@name='action_homologate_article']" position="after">
                <button
                    name="update_costs_action"
                    string="Update Cost"
                    type="object"
                    class="oe_inline oe_stat_button btn-success"
                />
            </xpath>
            <xpath
                expr="//notebook/page[@name='invoice']/field[@name='lines_ride']"
                position="before"
            >
                <div class="d-flex align-items-center" style="gap: 15px;">
                    <field name="product_type_selection" />
                    <button
                        name="action_export_template"
                        type="object"
                        string="Download Template"
                        state="draft"
                        class="btn-primary btn-info"
                    />
                </div>
            </xpath>
        </field>
    </record>
