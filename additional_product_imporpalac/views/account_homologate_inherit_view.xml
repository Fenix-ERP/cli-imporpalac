<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_account_homologate_form_inherit" model="ir.ui.view">
        <field name="name">account.homologate.form.inherit</field>
        <field name="model">account.homologate</field>
        <field
            name="inherit_id"
            ref="l10n_ec_purchase_reception.view_account_homologate_form"
        />
        <field name="arch" type="xml">
            <xpath expr="//sheet//group" position="after">
                    <div
                    class="o_form_sheet_bg"
                    style="margin-top: 10px; margin-left: 20px;"
                >
                            <label for="file" string="File" />
                        <div class="o_field_widget o_input_widget">
                            <field
                            name="file"
                            filename="file_name"
                            widget="binary"
                            options="{'no_open': True}"
                            class="oe_form_field_input"
                        />
                        </div>
                    </div>
                    <div
                    class="o_form_sheet_pg"
                    style="margin-top: 10px; margin-left: 35px; margin-bottom: 10px;"
                >
                            <button
                        name="action_import"
                        type="object"
                        string="Hologate Products"
                        class="btn btn-sm btn-primary"
                    />
                    <button
                        name="action_export_template"
                        type="object"
                        string="Export Template"
                        class="btn btn-sm btn-primary"
                    />
                    </div>
            </xpath>

        </field>
    </record>
</odoo>
