<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_product_template_imporpalac_form_inherit" model="ir.ui.view">
        <field name="name">product.template.imporpalac.form.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <xpath
                expr="//notebook//page[@name='general_information']"
                position="after"
            >
                <page string="Additional Information">
                    <group>
                        <group string="Detail 1">
                            <field name="product_article" />
                            <field name="product_brand" />
                            <field name="product_model" />
                            <field name="product_year" />
                            <field name="product_origin" />
                            <field name="product_side" />
                        </group>
                        <group string="Detail 2">
                            <field name="additional_1" />
                            <field name="additional_2" />
                            <field name="additional_3" />
                            <field name="additional_4" />
                            <field name="additional_5" />
                            <field name="additional_6" />
                        </group>
                    </group>
                </page>
            </xpath>
            <xpath expr="//field[@name='categ_id']" position="attributes">
                <attribute name="modifiers">{
                    "required": [["type", "=", "product"]]
                    }</attribute>
                <attribute name="required">type == 'product'</attribute>
            </xpath>
        </field>
    </record>
</odoo>
