<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_product_template_imporpalac_form_inherit" model="ir.ui.view">
        <field name="name">product.template.imporpalac.form.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <xpath
                expr="//notebook//page[@name='general_information']"
                position="after"
            >
                <page string="Additional Information">
                    <group>
                        <group string="Detalle 1">
                            <field name="articulo" />
                            <field name="marca" />
                            <field name="modelo" />
                            <field name="anio" />
                            <field name="procedencia" />
                            <field name="lado" />
                        </group>
                        <group string="Detalle 2">
                            <field name="adicional_1" />
                            <field name="adicional_2" />
                            <field name="adicional_3" />
                            <field name="adicional_4" />
                            <field name="adicional_5" />
                            <field name="adicional_6" />
                        </group>
                    </group>
                </page>
            </xpath>
            <xpath expr="//field[@name='categ_id']" position="attributes">
                <attribute name="modifiers">{
                    "required": [["type", "=", "product"]]
                }</attribute>
                <attribute name="required">type == 'product'</attribute>
            </xpath>
        </field>
    </record>
</odoo>
