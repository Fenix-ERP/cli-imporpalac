<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="view_stock_warehouse_internal_transfer" model="ir.ui.view">
        <field name="name">stock.warehouse.form.internal.transfer.inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form" />
        <field name="arch" type="xml">
            <xpath
                expr="//page//field[@name='move_ids_without_package']"
                position="before"
            >
                <button
                    name="action_internal_transfer_upload"
                    string="Import Internal Transfer"
                    type="object"
                    class="btn-primary"
                    invisible="picking_type_code != 'internal'"
                />
            </xpath>
        </field>
    </record>
</odoo>
