<odoo>
    <record id="view_import_transfer_product_wizard_form" model="ir.ui.view">
        <field name="name">import.transfer.product.wizard.form</field>
        <field name="model">import.transfer.product.wizard</field>
        <field name="arch" type="xml">
            <form string="Internal Transfer Products Import">
                <sheet>
                    <group>
                        <label for="file" class="oe_form_label">File</label>
                        <div class="o_field_widget o_input_widget">
                            <field
                                name="file"
                                filename="file_name"
                                widget="binary"
                                options="{'no_open': True}"
                                class="oe_form_field_input"
                                required="false"
                            />
                        </div>
                    </group>
                </sheet>

                <footer>
                    <button
                        name="action_import"
                        type="object"
                        string="Importar"
                        class="btn-primary"
                    />
                    <button string="Cancelar" special="cancel" class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>
</odoo>
