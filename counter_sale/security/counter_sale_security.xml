<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="module_category_counter_sale" model="ir.module.category">
        <field name="name">Counter Sale</field>
        <field name="description">Access groups for counter sale</field>
        <field name="sequence">10</field>
    </record>
    <record id="group_counter_sale_picker" model="res.groups">
        <field name="name">Picker</field>
        <field name="category_id" ref="module_category_counter_sale" />
    </record>
    <record id="group_counter_sale_dispatcher" model="res.groups">
        <field name="name">Dispatcher</field>
        <field name="category_id" ref="module_category_counter_sale" />
    </record>
    <record id="group_counter_sale_seller" model="res.groups">
        <field name="name">Seller</field>
        <field name="category_id" ref="module_category_counter_sale" />
    </record>
    <record id="group_counter_sale_identifier_editor" model="res.groups">
        <field name="name">Identifier/Vat Editor</field>
        <field name="users" eval="[(4, ref('base.user_admin'))]" />
    </record>
    <record id="group_counter_sale_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="category_id" ref="module_category_counter_sale" />
        <field
            name="implied_ids"
            eval="[
            (4, ref('counter_sale.group_counter_sale_picker')),
            (4, ref('counter_sale.group_counter_sale_dispatcher')),
            (4, ref('counter_sale.group_counter_sale_seller')),
        ]"
        />
        <field name="users" eval="[(4, ref('base.user_admin'))]" />
    </record>
    <record id="group_counter_sale_allow_view_amount_total" model="res.groups">
        <field name="name">Can view the fields hidden in sales</field>
        <field name="category_id" ref="module_category_counter_sale" />
    </record>
    <record id="group_counter_sale_allow_view_amount_total_account" model="res.groups">
        <field name="name">Can view amount total account</field>
        <field name="category_id" ref="module_category_counter_sale" />
    </record>
    <record id="group_counter_sale_hide_amount_on_groupby" model="res.groups">
        <field name="name">Hide amount fields on groupby</field>
        <field name="category_id" ref="module_category_counter_sale" />
    </record>
</odoo>
