<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="hide_total_signed_for_seller_tree" model="ir.ui.view">
        <field name="name">hide.amount_total_signed.for.seller.tree</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree" />
        <field name="priority" eval="100" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total_signed']" position="attributes">
                <attribute
                    name="groups"
                >counter_sale.group_counter_sale_allow_view_amount_total_account</attribute>
            </xpath>
            <xpath expr="//field[@name='amount_untaxed_signed']" position="attributes">
                <attribute
                    name="groups"
                >counter_sale.group_counter_sale_allow_view_amount_total_account</attribute>

            </xpath>
            <xpath expr="//field[@name='amount_tax_signed']" position="attributes">
                <attribute
                    name="groups"
                >counter_sale.group_counter_sale_allow_view_amount_total_account</attribute>

            </xpath>
            <xpath
                expr="//field[@name='amount_total_in_currency_signed'][@optional='show']"
                position="attributes"
            >
                <attribute
                    name="groups"
                >counter_sale.group_counter_sale_allow_view_amount_total_account</attribute>

            </xpath>
            <xpath
                expr="//field[@name='amount_total_in_currency_signed'][@optional='hide']"
                position="replace"
            />
        </field>
    </record>

    <record id="account_move_form_inherit_counter_sale" model="ir.ui.view">
        <field name="name">account.move.form.inherit.counter.sale</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_user_id']" position="attributes">
                <attribute name="readonly">state != 'draft'</attribute>
            </xpath>
        </field>
    </record>

    <record id="hide_sum_amount_on_groupby_tree" model="ir.ui.view">
        <field name="name">hide.sum.amount.on.groupby.tree</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree" />
        <field name="priority" eval="101" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total_signed']" position="attributes">
                <attribute
                    name="invisible"
                >not user_can_view_amount_on_groupby</attribute>
            </xpath>
            <xpath expr="//field[@name='amount_untaxed_signed']" position="attributes">
                <attribute
                    name="invisible"
                >not user_can_view_amount_on_groupby</attribute>
            </xpath>
            <xpath expr="//field[@name='amount_tax_signed']" position="attributes">
                <attribute
                    name="invisible"
                >not user_can_view_amount_on_groupby</attribute>
            </xpath>
            <xpath expr="//tree" position="inside">
                <field name="user_can_view_amount_on_groupby" column_invisible="1" />
            </xpath>
        </field>
    </record>
</odoo>
