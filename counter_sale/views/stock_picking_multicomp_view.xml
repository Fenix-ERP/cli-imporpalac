<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_picking_form_hide_ribbon_intercompany" model="ir.ui.view">
        <field name="name">stock.picking.form.hide.ribbon.intercompany</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form" />
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <field name="is_inter_company" invisible="1" />
            </xpath>
            <xpath expr="//widget[@name='web_ribbon']" position="attributes">
                <attribute name="invisible" add="is_inter_company" separator=" or " />
            </xpath>
        </field>
    </record>
</odoo>
