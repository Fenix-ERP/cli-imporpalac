<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_res_config_setting_inherit_price_list" model="ir.ui.view">
        <field name="name">res.config.settings.inherit.price.list</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//app[@name='sale_management']" position="inside">
                <h2>Price List</h2>
                <div class="row mt16 o_settings_container">
                    <div class="col-xs-6 col-md-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label
                                        class="col-lg-6"
                                        for="product_pricelist_ids_default"
                                    />
                                    <field
                                        name="product_pricelist_ids_default"
                                        widget="many2many_tags"
                                    />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
