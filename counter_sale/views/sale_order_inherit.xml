<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record model="ir.ui.view" id="view_sale_order_counter_sale">
        <field name="name">view.sales.order.inherit.counter.sale</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="before">
                <field name="is_inter_company" invisible="1" />
            </xpath>
            <xpath expr="//button[@name='action_open_payments']" position="attributes">
                <attribute name="invisible" add="is_inter_company" separator=" or " />
            </xpath>
            <xpath expr="//form" position="attributes">
                <attribute name="js_class">view_sale_order_counter_form</attribute>
            </xpath>
            <xpath expr="//button[@id='create_invoice']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='product_template_id']" position="attributes">
                <attribute name="options">{'no_create': True}</attribute>
            </xpath>
            <xpath
                expr="//div[@name='so_button_below_order_lines']"
                position="attributes"
            >
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='pricelist_id']" position="before">
                <field name="product_pricelist_domain" invisible="1" />
            </xpath>
            <xpath expr="//field[@name='pricelist_id']" position="attributes">
                <attribute name="domain">
                    product_pricelist_domain
                </attribute>
            </xpath>
            <xpath expr="//sheet//div" position="before">
                <field name="expired" invisible="1" />
                <widget
                    name="web_ribbon"
                    title="Expired"
                    bg_color="text-bg-danger"
                    invisible="not expired"
                />
            </xpath>
            <xpath
                expr="//button[@id='create_invoice_percentage']"
                position="attributes"
            >
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath
                expr="//button[@name='action_confirm' and @id='action_confirm']"
                position="attributes"
            >
                <attribute name="groups">
                    counter_sale.group_counter_sale_seller
                </attribute>
            </xpath>
            <xpath
                expr="//button[@name='action_confirm' and not(@id)]"
                position="attributes"
            >
                <attribute name="groups">
                    counter_sale.group_counter_sale_seller
                </attribute>
            </xpath>
            <xpath expr="//button[@name='action_cancel']" position="attributes">
                <attribute name="groups">
                    counter_sale.group_counter_sale_seller
                </attribute>
            </xpath>
            <xpath expr="//button[@name='action_draft']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@id='create_invoice']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='action_unlock']" position="attributes">
                <attribute name="groups">
                    counter_sale.group_counter_sale_admin
                </attribute>
            </xpath>
            <xpath expr="//button[@name='action_lock']" position="attributes">
                <attribute name="groups">
                    counter_sale.group_counter_sale_admin
                </attribute>
            </xpath>
            <xpath expr="//button[@name='action_cancel']" position="before">
                <button
                    name="action_cancel"
                    type="object"
                    string="Cancel"
                    class="btn-secondary"
                    groups="counter_sale.group_counter_sale_seller"
                    invisible="state not in ['draft', 'sent', 'sale'] or not locked"
                    data-hotkey="x"
                    context="{'force_dissable_locked': True,}"
                />
            </xpath>
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="readonly">state != 'draft'</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_order_form_inherit_pricelist_line_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.pricelist.line.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <xpath
                expr="/form/sheet/notebook/page/field[@name='order_line']/tree/field[@name='price_unit']"
                position="after"
            >
                <field name="product_pricelist_domain" column_invisible="1" />
            </xpath>
            <xpath
                expr="/form/sheet/notebook/page/field[@name='order_line']/tree/field[@name='line_pricelist_id']"
                position="attributes"
            >
                <attribute name="domain">
                    product_pricelist_domain
                </attribute>
            </xpath>
        </field>
    </record>

    <record id="action_print_ticket_server" model="ir.actions.server">
        <field name="name">Print Ticket</field>
        <field name="model_id" ref="model_sale_order" />
        <field name="binding_model_id" ref="model_sale_order" />
        <field name="binding_type">action</field>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field
            name="code"
        >action = env['sale.order'].action_print_ticket(record.id)</field>
    </record>

    <record id="hide_total_for_seller_tree_real" model="ir.ui.view">
        <field name="name">hide.total.for.seller.tree.real</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_tree" />
        <field name="priority" eval="100" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total']" position="attributes">
                <attribute
                    name="groups"
                >counter_sale.group_counter_sale_allow_view_amount_total</attribute>
            </xpath>
            <xpath expr="//field[@name='amount_untaxed']" position="attributes">
                <attribute
                    name="groups"
                >counter_sale.group_counter_sale_allow_view_amount_total</attribute>
            </xpath>
            <xpath expr="//field[@name='amount_tax']" position="attributes">
                <attribute
                    name="groups"
                >counter_sale.group_counter_sale_allow_view_amount_total</attribute>
            </xpath>
        </field>
    </record>
</odoo>
