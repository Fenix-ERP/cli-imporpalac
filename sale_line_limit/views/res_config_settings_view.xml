<odoo>
    <record id="view_sale_config_settings_limit" model="ir.ui.view">
        <field name="name">res.config.settings.sale.line.limit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath
                expr="//block[@name='quotation_order_setting_container']"
                position="inside"
            >
                <setting
                    id="sale_line_limit"
                    help="Restringe el número máximo de líneas en pedidos de venta"
                >
                    <field name="sale_line_restriction" />
                    <field
                        name="sale_line_max_count"
                        invisible="sale_line_restriction == False"
                    />
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
