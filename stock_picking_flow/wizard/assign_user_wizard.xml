<odoo>
    <record id="view_assign_user_wizard" model="ir.ui.view">
        <field name="name">assign.user.wizard.form</field>
        <field name="model">assign.user.wizard</field>
        <field name="arch" type="xml">
            <form string="Assign User">
                <field name="assign_type" invisible="1" />
                <group>
                    <div
                        class="alert alert-info mb16"
                        role="alert"
                        invisible="assign_type != 'picker'"
                    >
                        Select the user who will be assigned as picker to the selected transfers.
                    </div>

                    <div
                        class="alert alert-info mb16"
                        role="alert"
                        invisible="assign_type != 'driver'"
                    >
                        Select the user who will be assigned as driver to the selected transfers.
                    </div>
                    <group>
                        <field
                            name="picker_id"
                            invisible="assign_type != 'picker'"
                            required="assign_type == 'picker'"
                        />


                        <field
                            name="driver_id"
                            invisible="assign_type != 'driver'"
                            required="assign_type == 'driver'"
                        />
                    </group>
                </group>
                <footer>
                    <button
                        name="action_assign_picker"
                        type="object"
                        string="Assign Picker"
                        class="btn-primary"
                        invisible="assign_type != 'picker'"
                    />
                    <button
                        name="action_assign_driver"
                        type="object"
                        string="Assign Driver"
                        class="btn-primary"
                        invisible="assign_type != 'driver'"
                    />
                    <button string="Cancel" special="cancel" />
                </footer>
            </form>
        </field>
    </record>
</odoo>
