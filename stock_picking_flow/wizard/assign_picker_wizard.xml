<odoo>
    <record id="view_assign_picker_wizard" model="ir.ui.view">
        <field name="name">assign.picker.wizard.form</field>
        <field name="model">assign.picker.wizard</field>
        <field name="arch" type="xml">
            <form string="Assign Picker">
                <group>
                    <div class="alert alert-info mb16" role="alert">
                        Select the user who will be assigned as picker to the selected transfers.
                    </div>
                    <group>
                        <field
                            name="picker_id"
                            options="{'no_create': True}"
                            required="1"
                        />
                    </group>
                </group>
                <footer>
                    <button
                        name="action_assign"
                        type="object"
                        string="Assign Picker"
                        class="btn-primary"
                    />
                    <button string="Cancel" special="cancel" />
                </footer>
            </form>
        </field>
    </record>
</odoo>
