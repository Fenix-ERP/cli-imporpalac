<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record model="ir.ui.view" id="view_stock_picking_form_inherit_stock_picking_flow">
        <field name="name">view.stock.picking.form.inherit.stock.picking.flow</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form" />
        <field name="priority">19</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field
                    name="collection_state"
                    widget="statusbar"
                    statusbar_visible="waiting,assigned,confirmed"
                />
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <xpath expr="//field[@name='scheduled_date']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <xpath expr="//field[@name='origin']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="after">
                <field
                    name="picker_user_id"
                    widget="many2one_avatar_user"
                    readonly="1"
                />
            </xpath>
            <xpath
                expr="//button[@name='button_validate' and hasclass('oe_highlight')]"
                position="before"
            >
                <button
                    type="object"
                    string="Reserve Picking"
                    class="btn btn-primary"
                    name="action_reserve_picking"
                    invisible="collection_state!='waiting'"
                />
                <button
                    type="object"
                    string="Ready"
                    class="btn btn-primary"
                    name="action_confirm_picking"
                    invisible="collection_state!='assigned' or not is_owner_picker_user"
                />
            </xpath>
            <xpath expr="//field[@name='origin']" position="after">
                <field name="is_owner_picker_user" invisible="1" />
            </xpath>
            <xpath
                expr="//button[@name='button_validate' and hasclass('oe_highlight')]"
                position="attributes"
            >
                <attribute
                    name="invisible"
                    add="collection_state in ['waiting','assigned','cancel'] or (collection_state in ['issue','done'] and picking_type_code != 'incoming')"
                    separator=" or "
                />
            </xpath>
            <xpath
                expr="//button[@name='button_validate' and hasclass('o_btn_validate')]"
                position="attributes"
            >
                <attribute name="invisible">1 </attribute>
            </xpath>
            <xpath
                expr="//page[@name='operations']/field[@name='move_ids_without_package']/tree"
                position="attributes"
            >
                <attribute name="create">parent.state!='draft'</attribute>
                <attribute name="delete">parent.state!='draft'</attribute>
                <attribute
                    name="readonly"
                >not parent.is_owner_picker_user and parent.state!='draft'</attribute>
            </xpath>
            <xpath expr="//field[@name='quantity']" position="attributes">
                <attribute
                    name="readonly"
                    add="parent.collection_state not in ['assigned'] and parent.state in ['assigned','done','cancel']"
                    separator=" or "
                />
                <attribute name="sum">product_uom_qty</attribute>
            </xpath>
            <xpath expr="//field[@name='quantity']" position="after">
                <field
                    name="quantity"
                    string="Adjusted Quantity"
                    readonly="not is_quantity_done_editable"
                    column_invisible="parent.state not in ['assigned']"
                    groups="stock_picking_flow.group_logistics_supervisor"
                />
            </xpath>
            <xpath
                expr="//page[@name='extra']//group[@name='other_infos']//field[@name='user_id']"
                position="after"
            >
                <field
                    name="sale_person_id"
                    widget="many2one_avatar_user"
                    invisible="not sale_person_id"
                />
                <field
                    name="purchase_person_id"
                    widget="many2one_avatar_user"
                    invisible="not purchase_person_id"
                />
            </xpath>
            <xpath expr="//field[@name='date_deadline']" position="after">
                <field name="confirmed_date" />
            </xpath>
        </field>
    </record>
    <record model="ir.ui.view" id="view_stock_picking_tree_inherit_stock_picking_flow">
        <field name="name">view.stock.picking.tree.inherit.stock.picking.flow</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field
                    name="collection_state"
                    widget="badge"
                    decoration-warning="collection_state == 'waiting'"
                    decoration-info="collection_state == 'assigned'"
                    decoration-success="collection_state == 'confirmed'"
                    decoration-danger="collection_state == 'issue'"
                    optional="show"
                />
            </xpath>
        </field>
    </record>
    <record
        model="ir.ui.view"
        id="view_picking_internal_search_inherit_stock_picking_flow"
    >
        <field name="name">stock.picking.internal.search.stock.picking.flow</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_internal_search" />
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='available']" position="after">
                <separator />
                <filter
                    name="collection_waiting"
                    string="Collection Waiting"
                    domain="[('collection_state', '=', 'waiting')]"
                />
                <filter
                    name="collection_assigned"
                    string="Collection Assigned"
                    domain="[('collection_state', '=', 'assigned')]"
                />
                <filter
                    name="collection_confirmed"
                    string="Collection Confirmed"
                    domain="[('collection_state', '=', 'confirmed')]"
                />
                <filter
                    name="collection_issue"
                    string="Collection with Issue"
                    domain="[('collection_state', '=', 'issue')]"
                />
            </xpath>
            <xpath expr="//group[last()]" position="inside">
                <filter
                    string="Collection state"
                    name="group_by_collection_state"
                    domain="[]"
                    context="{'group_by': 'collection_state'}"
                />
            </xpath>
        </field>
    </record>
    <record id="action_assign_picker_wizard" model="ir.actions.act_window">
        <field name="name">Assign Picker</field>
        <field name="res_model">assign.picker.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="stock.model_stock_picking" />
        <field name="binding_view_types">list</field>
    </record>
</odoo>
