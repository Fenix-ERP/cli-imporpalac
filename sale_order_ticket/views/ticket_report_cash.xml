<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="report_ticket_cash_document">
        <t t-name="sale_order_ticket.report_ticket_cash_document">
            <style>
                .pos-ticket {
                    width: 240px; /* ~80mm */
                    font-family: monospace, Arial, sans-serif;
                    font-size: 12px;
                    margin: 0 auto;
                    padding: 5px 10px;
                    color: #000;
                }
                .pos-ticket img.pos-o-logo {
                    max-width: 150px;
                    max-height: 60px;
                    margin: 0 auto;
                    display: block;
                }
                .pos-center {
                    text-align: center;
                }
                .pos-line {
                    border-bottom: 1px dashed #000;
                    margin: 5px 0;
                }
                .pos-header {
                    font-weight: bold;
                    margin: 10px 0;
                }
                .pos-sale-order {
                    font-weight: bold;
                    font-size: 24px;
                    margin: 10px 0;
                }
                .pos-order-lines-header,
                .pos-order-line {
                    display: flex;
                    align-items: center;
                }
                .pos-order-lines-header {
                    font-weight: bold;
                    border-bottom: 2px solid #000;
                    padding-bottom: 4px;
                }
                .pos-order-line {
                    padding: 4px 0;
                    border-bottom: 1px dashed #ccc;
                }
                /* Flexes para controlar espacios */
                .flex-qty {
                    flex: 0 0 25px; /* cantidad fija, a la izquierda */
                    text-align: left;
                }
                .flex-product {
                    flex: 1 1 auto; /* ocupa todo lo posible */
                    padding-left: 5px;
                    overflow-wrap: break-word;
                }
                .flex-price {
                    flex: 0 0 60px;
                    text-align: right;
                    font-weight: bold;
                }
                .pos-info-line {
                    word-break: break-word;
                    white-space: normal;
                    margin: 2px 0;
                }
                .product-name-code {
                    display: inline-flex;
                    flex-direction: row;
                    flex-wrap: wrap;
                    word-break: break-word;
                    white-space: normal;
                }
                .total-line {
                    border-top: 1px solid #000;
                    padding-top: 4px;
                    margin-top: 0; /* ya no es necesario separar arriba si usamos align-items */
                    display: inline-block;
                }
                .product-code {
                    margin-left: 4px;
                    color: #444;
                    font-style: italic;
                }
            </style>

            <div class="pos-ticket">
                <img
                    class="pos-o-logo"
                    t-if="logo_custom"
                    t-att-src="'data:image/png;base64,%s' % logo_custom"
                    alt="Logo"
                    style="max-height:80px"
                />

                <div class="pos-center">
                    <t t-if="o.company_id.vat">
                        <t t-esc="o.company_id.vat" />
                    </t>
                    <br />
                    <t t-if="o.company_id.city and o.company_id.country_id">
                        <t t-esc="o.company_id.city" /> - <t
                            t-esc="o.company_id.country_id.name"
                        />
                    </t>
                </div>

                <div class="pos-line" />

                <div class="pos-center pos-header pos-sale-order">
                    Orden N:
                    <t t-esc="o.name" />
                </div>

                <div>
                    Fecha:
                    <span t-esc="o.date_order.strftime('%d/%m/%Y')" />
                </div>

                <div>
                    RUC:
                    <span t-esc="o.partner_id.vat" />
                </div>

                <div>
                    <t t-esc="o.partner_id.name" />
                </div>

                <div>
                    Direccion:
                    <t t-esc="o.partner_id.street" />
                </div>

                <div>
                    Telefono:
                    <t t-esc="o.partner_id.phone" />
                </div>

                <div>
                    <t t-esc="o.payment_method.name" />
                </div>
                <div>
                    <t t-esc="o.user_id.name" />
                </div>
                <div class="pos-line" />

                <div class="pos-order-lines-header">
                    <div class="flex-qty">Cant.</div>
                    <div class="flex-product">Descripción</div>
                    <div class="flex-price">Total</div>
                </div>

                <t t-foreach="o.order_line" t-as="line">
                    <div class="pos-order-line">
                        <div class="flex-qty">
                            <t t-esc="int(line.product_uom_qty)" />
                        </div>
                        <div class="flex-product">
                            <div class="product-name-code">
                                <t t-esc="line.product_id.name" />
                                <t t-if="line.product_id.default_code">
                                    <span class="product-code">
                                        [
                                        <t t-esc="line.product_id.default_code" />
                                        ]
                                    </span>
                                </t>
                            </div>
                        </div>

                        <div class="flex-price">
                            <t
                                t-esc="'{:.2f}'.format(line.price_unit * line.product_uom_qty)"
                            />
                        </div>
                    </div>
                </t>

                <div class="pos-line" />
                <div
                    style="display:flex; justify-content: space-between; font-weight: bold;"
                >
                    <div>Subtotal sin Desc:</div>
                    <div class="pos-right">
                        <t t-esc="'%.2f' %  o.amount_undiscounted" />
                    </div>
                </div>
                <!-- <div
                    style="display:flex; justify-content: space-between; font-weight: bold;"
                >
                    <div>Subtotal 0%:</div>
                    <div class="pos-right">
                        <t t-esc="'%.2f' %  o.amount_undiscounted" />
                    </div>
                </div> -->
                <div
                    style="display:flex; justify-content: space-between; font-weight: bold;"
                >
                    <div>Descuento:</div>
                    <div class="pos-right">
                        <t
                            t-esc="'%.2f' % abs(o.amount_untaxed - o.amount_undiscounted)"
                        />
                    </div>
                </div>
                <t t-set="tax_summary" t-value="{}" />
                <t t-set="tax_summary_vals" t-value="{}" />
                <t t-foreach="o.order_line" t-as="line">
                    <t t-set="taxes" t-value="line.tax_id" />
                    <t t-foreach="taxes" t-as="tax">
                        <t t-set="name" t-value="tax['name']+':'" />
                        <t t-set="amount" t-value="tax['amount']" />
                        <t t-set="type" t-value="tax['amount_type']" />
                        <t t-if="type == 'percent'">
                            <t t-set="value" t-value="line.price_subtotal*amount/100" />
                        </t>
                        <t t-else="">
                            <t t-set="value" t-value="line.price_subtotal+amount" />
                        </t>
                        <t t-set="sub" t-value="line.price_subtotal" />
                        <t t-set="acc" t-value="tax_summary.get(name, 0.0) + sub" />
                        <t
                            t-set="acc_val"
                            t-value="tax_summary_vals.get(name, 0.0) + value"
                        />
                        <t
                            t-set="tax_summary"
                            t-value="dict(tax_summary, **{name: acc})"
                        />
                        <t
                            t-set="tax_summary_vals"
                            t-value="dict(tax_summary_vals, **{name: acc_val})"
                        />
                    </t>
                </t>

                <!-- Subtotales por impuesto -->
                <t t-foreach="tax_summary.items()" t-as="tax_line">
                    <div
                        style="display:flex; justify-content: space-between; font-weight: bold;"
                    >
                        <div>
                            Subtotal
                            <t t-esc="tax_line[0]" />
                        </div>
                        <div class="pos-right">
                            <t t-esc="'%.2f' % tax_line[1]" />
                        </div>
                    </div>
                </t>
                <t t-foreach="tax_summary_vals.items()" t-as="taxv_line">
                    <div
                        style="display:flex; justify-content: space-between; font-weight: bold;"
                    >
                        <div>
                            <t t-esc="taxv_line[0]" />
                        </div>
                        <div class="pos-right">
                            <t t-esc="'%.2f' % taxv_line[1]" />
                        </div>
                    </div>
                </t>
                <div
                    style="display: flex; justify-content: space-between; align-items: flex-end; font-weight: bold;"
                >
                    <div>Total:</div>
                    <div class="pos-right total-line">
                        <t t-esc="'%.2f' % o.amount_total" />
                    </div>
                </div>

                <div class="pos-line" />

                <div class="pos-center" style="font-size: 10px;">
                    Documento sin validez tributaria
                    <br />
                    <span t-field="o.date_order" t-options="{'widget': 'datetime'}" />
                </div>
            </div>
        </t>
    </template>

    <template id="report_ticket_cash">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="sale_order_ticket.report_ticket_cash_document" />
            </t>
        </t>
    </template>
</odoo>
