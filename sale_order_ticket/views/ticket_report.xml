<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="report_ticket_document">
        <t t-name="Order" owl="1">
            <style>
                .pos-o {
                    width: 50%;
                    margin: auto;
                    border: 1px solid #000;
                    padding: 20px;
                }
            </style>
            <div class="pos-o">
                <t t-if="o.company_id.logo">
                    <img class="pos-o-logo" t-att-src="o.company_id.logo" alt="Logo" />
                </t>
                <t>
                    <h2 class="pos-o-center-align">
                        <t t-esc="o.company_id.name" />
                    </h2>
                </t>
                <div class="pos-o-contact">
                    <t t-if="o.company_id.phone">
                        <div>Tel:<t t-esc="o.company_id.phone" /></div>
                    </t>
                    <t t-if="o.company_id.vat">
                        <div><t t-esc="o.company_id.vat" /></div>
                    </t>
                    <t t-if="o.company_id.email">
                        <div><t t-esc="o.company_id.email" /></div>
                    </t>
                    <t t-if="o.company_id.website">
                        <div><t t-esc="o.company_id.website" /></div>
                    </t>
                </div>
                <br />
                <div class="page">
                    <h2 style="text-align:center">
                        <strong>Order N: <span t-field="o.name" /></strong>
                    </h2>
                </div>
                <h3 class="pos-o-center-align">
                    Customer: <t t-esc="o.partner_id.name" />
                </h3>
                <h3 class="pos-o-center-align">
                    Payment Method: <t t-esc="o.payment_method.name" />
                </h3>
                <div class="orderlines">
                    <div style="margin-bottom: 10px;">
                        <div
                            class="pos-receipt-left-padding"
                            style="display: inline-block; font-weight: bold; margin-right: 20px;"
                        >
                            Name
                        </div>
                        <div
                            class="pos-receipt-left-padding"
                            style="display: inline-block; font-weight: bold; margin-right: 20px;"
                        >
                            Price
                        </div>
                        <div
                            class="pos-receipt-left-padding"
                            style="display: inline-block; font-weight: bold; margin-right: 20px;"
                        >
                            Quantity
                        </div>
                        <div
                            class="pos-receipt-left-padding"
                            style="display: inline-block; font-weight: bold;"
                        >
                            Unit of Measure
                        </div>
                    </div>
                    <t t-foreach="o.order_line" t-as="line" t-key="line.id">
                        <div style="margin-bottom: 10px;">
                            <div
                                class="pos-receipt-left-padding"
                                style="display: inline-block; margin-right: 20px;"
                            >
                                <t t-esc="line.product_id.name" />
                            </div>
                            <div
                                class="pos-receipt-left-padding"
                                style="display: inline-block; margin-right: 20px;"
                            >
                                <t t-esc="line.price_unit" />
                            </div>
                            <t t-if="line.price_tax">
                                <div
                                    class="pos-receipt-left-padding"
                                    style="display: inline-block; margin-right: 20px;"
                                >
                                    <t t-esc="line.product_uom_qty" />
                                </div>
                            </t>
                            <div
                                class="pos-receipt-left-padding"
                                style="display: inline-block;"
                            >
                                <t t-esc="line.product_uom.name" />
                            </div>
                        </div>
                    </t>
                </div>

                <!-- Subtotal -->
                <t>
                    <div class="pos-receipt-right-align">--------</div>
                    <br />
                    <div class="pos-receipt-amount">
                        Subtotal
                        <span
                            t-esc="o.amount_untaxed"
                            class="pos-receipt-right-align"
                        />
                    </div>
                </t>

                <!-- Total -->
                <div class="pos-receipt-right-align">--------</div>
                <br />
                <div class="pos-receipt-amount">
                    TOTAL
                    <span t-esc="o.amount_total" class="pos-receipt-right-align" />
                </div>
                <br /><br />
                <div class="pos-receipt-order-data">
                    <div><t t-esc="o.date_order" /></div>
                </div>
            </div>
        </t>
    </template>

    <template id="report_ticket">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="sale_order_ticket.report_ticket_document" />
            </t>
        </t>
    </template>
</odoo>
