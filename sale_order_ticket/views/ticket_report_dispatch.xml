<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="report_ticket_dispatch_document">
        <t t-name="sale_order_ticket.report_ticket_dispatch_document">
            <style>
                .pos-ticket {
                    width: 245px; /* ~80mm */
                    font-family: monospace, Arial, sans-serif;
                    font-size: 12px;
                    margin: 0 auto;
                    padding: 5px 10px;
                    color: #000;
                }
                .pos-ticket img.pos-o-logo {
                    max-width: 150px;
                    max-height: 60px;
                    margin: 0 auto;
                    display: block;
                }
                .pos-center {
                    text-align: center;
                }
                .pos-line {
                    border-bottom: 1px dashed #000;
                    margin: 5px 0;
                }
                .pos-header {
                    font-weight: bold;
                    margin: 10px 0;
                }
                .pos-sale-order {
                    font-weight: bold;
                    font-size: 24px;
                    margin: 10px 0;
                }
                .pos-order-lines-header,
                .pos-order-line {
                    display: flex;
                    align-items: center;
                }
                .pos-order-lines-header {
                    font-weight: bold;
                    border-bottom: 2px solid #000;
                    padding-bottom: 4px;
                }
                .pos-order-line {
                    padding: 4px 0;
                    border-bottom: 1px dashed #ccc;
                }
                /* Flexes para controlar espacios */
                .flex-qty {
                    flex: 0 0 25px; /* cantidad fija, a la izquierda */
                    text-align: left;
                }
                .flex-product {
                    flex: 1 1 auto; /* ocupa todo lo posible */
                    padding-left: 5px;
                    overflow-wrap: break-word;
                }
                .flex-price {
                    flex: 0 0 60px;
                    text-align: right;
                    font-weight: bold;
                    font-size: 10px;
                }
                .pos-info-line {
                    word-break: break-word;
                    white-space: normal;
                    margin: 2px 0;
                }
                .product-name-code {
                    display: inline-flex;
                    flex-direction: row;
                    flex-wrap: wrap;
                    word-break: break-word;
                    white-space: normal;
                }

                .product-code {
                    margin-left: 4px;
                    color: #444;
                    font-style: italic;
                }
            </style>

            <div class="pos-ticket">

                <div class="pos-center">
                    <img
                        class="pos-o-logo"
                        t-if="logo_custom"
                        t-att-src="'data:image/png;base64,%s' % logo_custom"
                        alt="Logo"
                        style="max-height:80px"
                    />
                    <t t-if="o.company_id.city and o.company_id.country_id">
                        <t t-esc="o.company_id.city" /> - <t
                            t-esc="o.company_id.country_id.name"
                        />
                    </t>
                </div>
                <div class="pos-line" />

                <div class="pos-center pos-header pos-sale-order">
                    Orden N:
                    <t t-esc="o.name" />
                </div>

                <div>
                    RUC:
                    <span t-esc="o.partner_id.vat" />
                </div>

                <div>
                    <t t-esc="o.partner_id.name" />
                </div>

                <div>
                    <t t-esc="o.payment_method.name" />
                </div>
                <div>
                    <t t-esc="o.user_id.name" />
                </div>

                <div class="pos-line" />

                <div class="pos-order-lines-header">
                    <div class="flex-qty">Cant.</div>
                    <div class="flex-product">Descripción</div>
                    <div class="flex-price">Total</div>
                </div>

                <t t-foreach="o.order_line" t-as="line">
                    <div class="pos-order-line">
                        <div class="flex-qty">
                            <t t-esc="int(line.product_uom_qty)" />
                        </div>
                        <div class="flex-product">
                            <div class="product-name-code">
                                <t t-esc="line.product_id.name" />
                                <t t-if="line.product_id.default_code">
                                    <span class="product-code">
                                        [
                                        <t t-esc="line.product_id.default_code" />
                                        ]
                                    </span>
                                </t>
                            </div>
                        </div>

                        <div class="flex-price">
                            <t
                                t-esc="'{:.2f}'.format(line.price_unit * line.product_uom_qty)"
                            />
                        </div>
                    </div>
                </t>

                <div class="pos-line" />
                <div
                    style="display:flex; justify-content: space-between; font-weight: bold;"
                >
                    <div>Subtotal:</div>
                    <div class="pos-right">
                        <t t-esc="o.amount_untaxed" />
                    </div>
                </div>

                <div
                    style="display:flex; justify-content: space-between; font-weight: bold;"
                >
                    <div clas="flex-price">Total:</div>
                    <div class="flex-price">
                        <t t-esc="o.amount_total" />
                    </div>
                </div>

                <div class="pos-line" />
                <div class="pos-order-lines-header">
                    <div class="flex-qty">Nota</div>
                    <div class="flex-product">Descripción</div>
                </div>
                <t t-if="o.note">
                    <div class="flex-product">
                        <t t-esc="o.note" />
                    </div>
                </t>
                <div class="pos-line" />
                <div class="pos-center">
                    <t t-esc="o.date_order" />
                </div>
            </div>
        </t>
    </template>

    <template id="report_ticket_dispatch">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="sale_order_ticket.report_ticket_dispatch_document" />
            </t>
        </t>
    </template>
</odoo>
