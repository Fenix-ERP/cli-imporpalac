<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="action_report_ticket_receipt" model="ir.actions.report">
        <field name="name">Quotation Ticket</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">sale_order_ticket.report_ticket</field>
        <field name="report_file">sale_order_ticket.report_ticket</field>
        <field name="print_report_name">'Ticker %s' % (object.name)</field>
        <field name="binding_model_id" ref="sale.model_sale_order" />
        <field name="binding_type">report</field>
    </record>
    <record id="action_report_ticket_cash" model="ir.actions.report">
        <field name="name">Quotation Ticket</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">sale_order_ticket.report_ticket_cash</field>
        <field name="report_file">sale_order_ticket.report_ticket_cash</field>
        <field name="print_report_name">'Ticker %s' % (object.name)</field>
        <field name="binding_model_id" ref="sale.model_sale_order" />
        <field name="binding_type">report</field>
    </record>
</odoo>
