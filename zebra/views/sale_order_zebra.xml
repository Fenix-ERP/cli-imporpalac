<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_picking_form_inherit_label_button" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.label.button</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_open_print_wizard"
                    string="Zebra"
                    type="object"
                    class="btn-primary"
                    icon="fa-print"
                />
            </xpath>
        </field>
    </record>
</odoo>
