<odoo>
    <record id="product_template_zebra_form_view_inherit" model="ir.ui.view">
        <field name="name">product.template.zebra.form.view.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_open_print_wizard"
                    string="Zebra"
                    type="object"
                    class="btn-primary"
                    icon="fa-print"
                />
            </xpath>
        </field>
    </record>
</odoo>
