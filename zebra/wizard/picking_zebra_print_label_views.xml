<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Views of wizard -->
    <record id="view_print_label_wizard_form" model="ir.ui.view">
        <field name="name">print.label.wizard.form</field>
        <field name="model">print.label.wizard</field>
        <field name="arch" type="xml">
            <form string="Print Options">
                <sheet>
                    <field name="show_count" invisible="1" />
                    <group>
                        <group>
                            <field name="barcode_type" />
                        </group>
                        <group>
                            <field name="count" invisible="not show_count" />
                        </group>
                    </group>
                </sheet>
                <footer>

                    <button
                        name="action_print_labels"
                        string="Imprimir"
                        type="object"
                        class="btn-primary"
                    />
                    <button string="Cancelar" class="btn-secondary" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <!-- Action del wizard -->
    <record id="action_print_label_wizard" model="ir.actions.act_window">
        <field name="name">Print Options</field>
        <field name="res_model">print.label.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
