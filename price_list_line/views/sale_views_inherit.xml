<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_order_form_inherit_pricelist_line" model="ir.ui.view">
        <field name="name">sale.order.form.pricelist.line</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <xpath
                expr="/form/sheet/notebook/page/field[@name='order_line']/tree/field[@name='price_unit']"
                position="after"
            >
                <field name="line_pricelist_id" />
            </xpath>
        </field>
    </record>
</odoo>
