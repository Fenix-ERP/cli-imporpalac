<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record model="ir.ui.view" id="view_pay_res_partner_inherit_imporpalac">
        <field name="name">view.pay.res.partner.inherit.imporpalac</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <xpath
                expr="//page[@name='sales_purchases']//field[@name='property_payment_term_id']"
                position="after"
            >
                <field
                    name="payment_method"
                    options="{'no_create': True}"
                    required="1"
                />
            </xpath>
            <xpath expr="//field[@id='company']" position="attributes">
                <attribute name="readonly">is_end_consumer</attribute>
            </xpath>
            <xpath expr="//field[@id='individual']" position="attributes">
                <attribute name="readonly">is_end_consumer</attribute>
            </xpath>
            <xpath expr="//field[@name='identifier']" position="attributes">
                <attribute name="readonly">is_end_consumer</attribute>
            </xpath>
            <xpath expr="//field[@name='type_identifier']" position="attributes">
                <attribute name="readonly">is_end_consumer</attribute>
            </xpath>
            <xpath expr="//field[@name='vat']" position="attributes">
                <attribute name="readonly">is_end_consumer</attribute>
            </xpath>
        </field>
    </record>
</odoo>
