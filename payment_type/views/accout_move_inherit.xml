<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record model="ir.ui.view" id="view_account_move_inherit_imporpalac">
        <field name="name">view.account.move.inherit.imporpalac</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='voucher_type_ats']" position="after">
                <field
                    name="payment_method"
                    readonly="state in ('posted', 'cancel')"
                    options="{'no_create': True}"
                />
            </xpath>
        </field>
    </record>

    <record model="ir.ui.view" id="view_account_move_tree_inherit_imporpalac">
        <field name="name">view.account.move.tree.inherit.imporpalac</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="payment_method" optional="hide" />
            </xpath>
        </field>
    </record>

</odoo>
