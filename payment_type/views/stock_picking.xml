<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record model="ir.ui.view" id="view_stock_picking_tree_inherit_imporpalac">
        <field name="name">view.stock.picking.tree.inherit.imporpalac</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_approve"
                    string="Approve"
                    type="object"
                    class="btn-primary"
                    icon="fa-check"
                />
            </xpath>
            <xpath expr="//field[@name='state']" position="after">
                <field name="payment_method" optional="show" />
                <field name="paid" optional="show" />
                <field name="invoice_number" optional="show" />
            </xpath>
        </field>
    </record>
</odoo>
