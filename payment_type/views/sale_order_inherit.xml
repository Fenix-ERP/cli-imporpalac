<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record model="ir.ui.view" id="view_pay_sales_order_inherit_imporpalac">
        <field name="name">view.pay.sales.order.inherit.imporpalac</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field
                    name="payment_method"
                    readonly="state in ('sale', 'done')"
                    options="{'no_create': True}"
                />
                <field name="warehouse_id" />
            </xpath>
        </field>
    </record>
    <record id="view_order_form_inherit_with_image" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.image</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <xpath
                expr="//field[@name='order_line']/tree/field[@name='name']"
                position="before"
            >
                <field name="image_1920" widget="image" readonly="1" optional="show" />
            </xpath>
        </field>
    </record>
</odoo>
