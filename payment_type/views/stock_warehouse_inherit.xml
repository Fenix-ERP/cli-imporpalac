<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_stock_warehouse_form_journal" model="ir.ui.view">
        <field name="name">stock.warehouse.journal</field>
        <field name="model">stock.warehouse</field>
        <field name="inherit_id" ref="stock.view_warehouse" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='code']" position="after">
                <field name="journal_id" />
            </xpath>
            <xpath expr="//page[@name='warehouse_config']" position="after">
                <page string="Payment Methods">
                    <field name="payment_method_ids">
                        <tree editable="bottom">
                            <field
                                name="current_payment_type_ids_domain"
                                column_invisible="True"
                            />
                            <field
                                name="payment_type_id"
                                domain="current_payment_type_ids_domain"
                                options="{'no_create': True}"
                            />
                            <field
                                name="journal_payment_ids"
                                widget="many2many_tags"
                                options="{'no_create': True}"
                            />
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
