<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record model="ir.ui.view" id="payment_type_view_form">
        <field name="name">payment.type.view.form</field>
        <field name="model">payment.type</field>
        <field name="arch" type="xml">
            <form string="Type Payment Form">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record model="ir.ui.view" id="payment_type_view_list">
        <field name="name">payment.type.view.list</field>
        <field name="model">payment.type</field>
        <field name="arch" type="xml">
            <tree string="Type Payment List">
                <field name="name" />
            </tree>
        </field>
    </record>

    <record model="ir.ui.view" id="payment_type_view_search">
        <field name="name">payment.type.view.search</field>
        <field name="model">payment.type</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
            </search>
        </field>
    </record>

    <record id="payment_type_action" model="ir.actions.act_window">
        <field name="name">Payment type</field>
        <field name="res_model">payment.type</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Can you create the first payment type
            </p>
        </field>
    </record>

    <menuitem
        id="menu_payment_type"
        name="Payment type"
        parent="sale.menu_sale_config"
        action="payment_type_action"
        sequence="10"
    />
</odoo>
