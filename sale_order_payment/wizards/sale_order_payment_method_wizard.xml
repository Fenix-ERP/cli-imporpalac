<odoo>
    <record id="sale_order_payment_method_view_form" model="ir.ui.view">
        <field name="name">sale.order.payment.method.wizard.form</field>
        <field name="model">sale.order.payment.method.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirm Payment Method">
                <sheet>
                    <div>
                        <p invisible="is_pdc">Please select the payment method</p>
                    </div>
                    <group col="2">
                        <group>
                            <field name="partner_id" readonly="1" />
                            <field
                                name="reference"
                                invisible="is_mixed_payment or is_pdc"
                            />
                            <field name="available_journal_ids" invisible="1" />
                            <field name="sale_order_payment_id" invisible="1" />
                            <field name="payment_method_domain" invisible="1" />
                            <field name="is_mixed_payment" invisible="1" />
                            <field name="currency_id" invisible="1" />
                        </group>
                        <group>
                            <field
                                name="balance"
                                readonly="1"
                                widget='monetary'
                                options="{'currency_field': 'currency_id'}"
                            />
                            <field
                                name="residual"
                                invisible="not is_mixed_payment"
                                readonly="1"
                                widget='monetary'
                                options="{'currency_field': 'currency_id'}"
                            />
                            <field
                                name="payment_method_line_id"
                                options="{'no_create': True}"
                                invisible='is_mixed_payment or is_pdc'
                                required='not is_pdc'
                            />
                            <field
                                name="sale_order_payment_method_code"
                                options="{'no_create': True}"
                                invisible="1"
                            />
                            <field
                                name="card_id"
                                options="{'no_create': True}"
                                invisible="sale_order_payment_method_code!='credit_card' or is_mixed_payment"
                            />
                        </group>
                    </group>
                    <separator string="Postdated Check Info" invisible="not is_pdc" />
                    <group col="2">
                        <field name="is_pdc" invisible="1" />
                        <group>
                            <field
                                name="chq_agent"
                                invisible="not is_pdc"
                                required="is_pdc"
                            />
                            <field
                                name="chq_refr"
                                invisible="not is_pdc"
                                required="is_pdc"
                            />
                            <field
                                name="chq_bank_details"
                                invisible="not is_pdc"
                                required="is_pdc"
                            />
                        </group>
                        <group>
                            <field
                                name="chq_payment_date"
                                invisible="not is_pdc"
                                required="is_pdc"
                            />
                            <field
                                name="chq_due_date"
                                invisible="not is_pdc"
                                required="is_pdc"
                            />
                            <field
                                name="chq_amount"
                                invisible="not is_pdc or not is_mixed_payment"
                                required="is_pdc and is_mixed_payment"
                            />
                        </group>
                        <separator string="" invisible="not is_pdc" />
                    </group>
                    <field
                        name="method_line_ids"
                        nolabel="1"
                        invisible='not is_mixed_payment'
                    >
                        <tree editable="bottom">
                            <field
                                name="journal_id"
                                options="{'no_create': True}"
                                domain="[('id','in',available_journal_ids)]"
                            />
                            <field name="available_journal_ids" column_invisible="1" />
                            <field
                                name="available_payment_method_line_ids"
                                column_invisible="1"
                            />
                            <field
                                name="payment_method_line_id"
                                options="{'no_create': True}"
                                required="1"
                            />
                            <field name="card_required" column_invisible="1" />
                            <field
                                name="card_id"
                                invisible="not card_required"
                                column_invisible="context.get('payment_method') != 'credit_card'"
                                options="{'no_create': True}"
                            />
                            <field name="reference" options="{'no_create': True}" />
                            <field name="amount" />
                            <field
                                name="currency_id"
                                optional="hide"
                                options="{'no_create': True}"
                            />
                        </tree>
                    </field>
                </sheet>
                <footer>
                    <button
                        type="object"
                        string="Confirm"
                        class="btn btn-primary"
                        name="action_confirm"
                    />
                    <button
                        string="Cancel "
                        class="btn-secondary"
                        special="cancel"
                        data-hotkey="x"
                    />
                </footer>
            </form>
        </field>
    </record>
</odoo>
