<odoo>
    <record id="sale_order_payment_company_rule" model="ir.rule">
        <field name="name">Filtrar pagos por empresa</field>
        <field name="model_id" ref="model_sale_order_payment"/>
        <field name="domain_force">[('company_id', '=', user.company_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>
