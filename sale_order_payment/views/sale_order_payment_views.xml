<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_sale_order_payment_tree" model="ir.ui.view">
        <field name="name">sale.order.payment.tree</field>
        <field name="model">sale.order.payment</field>
        <field name="arch" type="xml">
            <tree
                string="Pagos de Orden de Venta"
                create="false"
                default_order="date_order desc"
            >
                <field name="client_id" />
                <field name="order_id" widget="many2one" />
                <field name="date_order" optional="hide" />
                <field name="hour_register" />
                <field name="amount" />
                <field name="rectified_order_id" />
                <field name="rectified_date_order" optional="hide" />
                <field name="rectified_amount" />
                <field name="difference" />
                <field name="payment_method" />
                <field name="payment_method_line_id" readonly="1" optional="show" />
                <field name="card_id" readonly="1" optional="hide" />
                <field name="reference" readonly="1" optional="hide" />
                <field name="available_payment_method_line_ids" column_invisible="1" />
                <field name="journal_id" optional="hide" />
                <field
                    name="is_mixed_payment"
                    readonly="state!='draft'"
                    widget="boolean_toggle"
                />
                <field
                    name="state"
                    widget="badge"
                    decoration-info="state == 'draft'"
                    decoration-success="state == 'processed'"
                    decoration-danger="state == 'cancel'"
                />
                <field
                    name="delivery_status"
                    widget="badge"
                    decoration-danger="delivery_status == 'waiting'"
                    decoration-warning="delivery_status == 'picking'"
                    decoration-muted="delivery_status == 'to_deliver'"
                    decoration-success="delivery_status == 'delivered'"
                />
                <field name="company_id" optional="hide" />
            </tree>
        </field>
    </record>

    <record id="view_sale_order_payment_tree_inherit_payment_button" model="ir.ui.view">
        <field name="name">sale.order.payment.tree.inherit.payment.button</field>
        <field name="model">sale.order.payment</field>
        <field
            name="inherit_id"
            ref="sale_order_payment.view_sale_order_payment_tree"
        />
        <field name="arch" type="xml">
            <xpath expr="//tree/field[@name='state']" position="before">
                <button
                    name="process_payment"
                    type="object"
                    icon="fa-money"
                    string="Cobrar"
                    invisible="state not in ['draft'] or not difference >= 0.0"
                    class="btn-primary"
                />
                <button
                    name="process_payment"
                    type="object"
                    icon="fa-money"
                    string="Devolver"
                    class="btn-danger"
                    invisible="state not in ['draft','cancel'] or difference >= 0.0"
                />
            </xpath>
        </field>
    </record>

    <record id="view_sale_order_payment_search" model="ir.ui.view">
        <field name="name">sale.order.payment.search</field>
        <field name="model">sale.order.payment</field>
        <field name="arch" type="xml">
            <search string="Buscar Pagos">
                <field name="client_id" string="Contacto" />
                <field name="date_order" string="Fecha" />
                <filter name="date_order" string="Date" date="date_order" />
                <group name="groupby" string="Group by">
                    <filter
                        name="client_groupby"
                        string="Partner"
                        context="{'group_by': 'client_id'}"
                    />
                    <filter
                        name="journal_groupby"
                        string="Journal"
                        context="{'group_by': 'journal_id'}"
                    />
                    <filter
                        name="date_groupby"
                        string="Date"
                        context="{'group_by': 'date_order'}"
                    />
                    <filter
                        name="state_groupby"
                        string="State"
                        context="{'group_by': 'state'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <record id="sale_order_payment_action" model="ir.actions.act_window">
        <field name="name">Sale Payments</field>
        <field name="res_model">sale.order.payment</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_sale_order_payment_tree" />
        <field name="search_view_id" ref="view_sale_order_payment_search" />
    </record>

    <menuitem
        id="menu_sale_order_payment_root"
        name="Sale Payments"
        parent="sale.sale_order_menu"
        action="sale_order_payment_action"
        sequence="20"
    />
</odoo>
