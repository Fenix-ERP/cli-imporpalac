<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template
        id="sale_order_document_inherited"
        inherit_id="sale.report_saleorder_document"
        priority="100"
    >
        <xpath expr="//div[@class='page']" position="inside">
            <t t-set="address">
            </t>
        </xpath>
        <xpath expr="//div[span[@t-field='doc.note']]" position="replace">
            <div>
                <p>
                    <strong>Payment Method:</strong>
                    <span t-field="doc.payment_method" />
                </p>
            </div>
        </xpath>

        <xpath expr="//h2[@class='mt-4']" position="replace">
            <h2 class="mt-4 text-end">
                <span
                    t-if="env.context.get('proforma', False) or is_pro_forma"
                >Pro-Forma Invoice # </span>
                <span t-elif="doc.state in ['draft','sent']">Quotation # </span>
                <span t-else="">Order # </span>
                <span t-field="doc.name">SO0000</span>
            </h2>
        </xpath>

        <xpath
            expr="//t[contains(@t-if, 'doc.partner_shipping_id == doc.partner_invoice_id')]"
            position="replace"
        >
            <div class="d-flex justify-content-between align-items-start">
                <div class="text-start">
                    <t t-set="information_block">
                        <div
                            t-field="doc.partner_invoice_id"
                            t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}'
                            style="font-size: 12px;"
                        />
                        <t t-if="doc.partner_shipping_id != doc.partner_invoice_id">
                            <strong>Shipping Address:</strong>
                            <div
                                t-field="doc.partner_shipping_id"
                                t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}'
                                style="font-size: 12px;"
                            />
                        </t>
                        <p t-if="doc.partner_id.vat">
                            <t
                                t-if="doc.company_id.account_fiscal_country_id.vat_label"
                                t-out="doc.company_id.account_fiscal_country_id.vat_label"
                            />
                            <t t-else="">Tax ID</t>: <span
                                t-field="doc.partner_id.vat"
                            />
                        </p>
                    </t>
                </div>
            </div>
        </xpath>
        <xpath expr="//div[@t-if='doc.user_id.name']" position="after">
            <div class="col-auto col-3 mw-100 mb-2" name="new_info">
                <strong>Num Vendor:</strong><br />
                <span class="m-0"><t t-esc="doc.user_id.partner_id.phone" /></span>
            </div>
        </xpath>

        <xpath
            expr="//table[@class='table table-sm o_main_table table-borderless mt-4']"
            position="replace"
        >
            <table class="table table-sm o_main_table table-borderless mt-4">
                <thead style="display: table-row-group">
                    <tr>
                        <th name="th_description" class="text-start">DESCRIPTION</th>
                        <th name="th_quantity" class="text-end">QUANTITY</th>
                        <th name="th_priceunit" class="text-end">PRICE UNIT</th>
                        <th name="th_discount" t-if="display_discount" class="text-end">
                            <span>DESC.%</span>
                        </th>
                        <th name="th_subtotal" class="text-end">
                            <span>TOTAL</span>
                        </th>
                    </tr>
                </thead>
                <tbody class="sale_tbody" style="font-size: 11px">

                    <t t-set="current_subtotal" t-value="0" />

                    <t t-foreach="lines_to_report" t-as="line">

                        <t
                            t-set="current_subtotal"
                            t-value="current_subtotal + line.price_subtotal"
                        />

                        <tr
                            t-att-class="'bg-200 fw-bold o_line_section' if line.display_type == 'line_section' else 'fst-italic o_line_note' if line.display_type == 'line_note' else ''"
                        >
                            <t t-if="not line.display_type">
                                <td
                                    style="padding: 2px 5px; vertical-align: middle;"
                                    name="td_name"
                                ><span t-field="line.name">Bacon Burger</span></td>
                                <td
                                    style="padding: 2px 5px; vertical-align: middle;"
                                    name="td_quantity"
                                    class="text-end"
                                >
                                    <span t-field="line.product_uom_qty">3</span>
                                    <span t-if="line.product_packaging_id">
                                        (<span
                                            t-field="line.product_packaging_qty"
                                            t-options='{"widget": "integer"}'
                                        /> <span t-field="line.product_packaging_id" />)
                                    </span>
                                </td>
                                <td
                                    style="padding: 2px 5px; vertical-align: middle;"
                                    name="td_priceunit"
                                    class="text-end"
                                >
                                    <span
                                        t-esc="line.price_unit"
                                        t-options='{"widget": "monetary", "display_currency": line.currency_id, "precision": 2}'
                                    />
                                </td>
                                <td
                                    t-if="display_discount"
                                    style="padding: 2px 5px; vertical-align: middle;"
                                    class="text-end"
                                >
                                    <span t-field="line.discount">-</span>
                                </td>
                                <td
                                    t-if="not line.is_downpayment"
                                    name="td_subtotal"
                                    style="padding: 2px 5px; vertical-align: middle; text-align: right;"
                                    class="text-end o_price_total"
                                >
                                    <span t-field="line.price_subtotal">27.00</span>
                                </td>
                            </t>
                            <t t-elif="line.display_type == 'line_section'">
                                <td
                                    style="padding: 2px 5px; vertical-align: middle;"
                                    name="td_section_line"
                                    colspan="99"
                                >
                                    <span t-field="line.name">A section title</span>
                                </td>
                                <t t-set="current_section" t-value="line" />
                                <t t-set="current_subtotal" t-value="0" />
                            </t>
                            <t t-elif="line.display_type == 'line_note'">
                                <td
                                    style="padding: 2px 5px; vertical-align: middle;"
                                    name="td_note_line"
                                    colspan="99"
                                >
                                    <span
                                        t-field="line.name"
                                    >A note, whose content usually applies to the section or product above.</span>
                                </td>
                            </t>
                        </tr>

                        <t
                            t-if="current_section and (line_last or lines_to_report[line_index+1].display_type == 'line_section') and not line.is_downpayment"
                        >
                            <tr class="is-subtotal text-end">
                                <td name="td_section_subtotal" colspan="99">
                                    <strong class="mr16">Subtotal</strong>
                                    <span
                                        t-out="current_subtotal"
                                        t-options='{"widget": "monetary", "display_currency": doc.currency_id}'
                                    >31.05</span>
                                </td>
                            </tr>
                        </t>
                    </t>
                </tbody>
            </table>
        </xpath>
        <xpath expr="//div[@id='total']" position="replace">
            <div id="total" class="row" name="total">
                <div
                    t-attf-class="#{'col-6' if report_type != 'html' else 'col-sm-7 col-md-6'} ms-auto"
                >
                    <table class="table table-sm table-borderless">

                        <t t-set="subtotal" t-value="0" />
                        <t t-set="discount_total" t-value="0" />
                        <t t-set="tax_total" t-value="0" />

                        <t t-foreach="lines_to_report" t-as="line">
                            <t
                                t-set="subtotal"
                                t-value="subtotal + (line.price_unit * line.product_uom_qty)"
                            />
                            <t
                                t-set="discount_total"
                                t-value="discount_total + ((line.price_unit * line.product_uom_qty) * (line.discount/100))"
                            />
                            <t t-set="tax_total" t-value="tax_total + line.price_tax" />
                        </t>

                        <tr>
                            <td
                                style="padding: 2px 5px; vertical-align: middle;"
                            ><strong>Subtotal</strong></td>
                            <td
                                style="padding: 2px 5px; vertical-align: middle; text-align: right;"
                                class="text-end"
                            >
                                <span
                                    t-esc="subtotal"
                                    t-options='{"widget": "monetary", "display_currency": doc.currency_id}'
                                />
                            </td>
                        </tr>

                        <tr>
                            <td
                                style="padding: 2px 5px; vertical-align: middle;"
                            ><strong>Descuento</strong></td>
                            <td
                                style="padding: 2px 5px; vertical-align: middle; text-align: right;"
                                class="text-end"
                            >
                                <span
                                    t-esc="discount_total"
                                    t-options='{"widget": "monetary", "display_currency": doc.currency_id}'
                                />
                            </td>
                        </tr>

                        <tr>
                            <td
                                style="padding: 2px 5px; vertical-align: middle;"
                            ><strong>IVA</strong></td>
                            <td
                                style="padding: 2px 5px; vertical-align: middle; text-align: right;"
                                class="text-end"
                            >
                                <span
                                    t-esc="tax_total"
                                    t-options='{"widget": "monetary", "display_currency": doc.currency_id}'
                                />
                            </td>
                        </tr>

                        <tr>
                            <td
                                style="padding: 2px 5px; vertical-align: middle;"
                            ><strong>Total</strong></td>
                            <td
                                style="padding: 2px 5px; vertical-align: middle; text-align: right;"
                                class="text-end"
                            >
                                <span
                                    t-esc="subtotal - discount_total + tax_total"
                                    t-options='{"widget": "monetary", "display_currency": doc.currency_id}'
                                />
                            </td>
                        </tr>

                    </table>
                </div>
            </div>
        </xpath>

    </template>

    <template
        id="web_boxed_document_inherited"
        inherit_id="web.external_layout_bold"
        priority="100"
    >
        <xpath expr="//div[@class='o_clean_header']" position="replace">
            <div class="row mb-2">
                <div
                    class="col-12 text-center"
                    style="font-size: 12px; line-height: 1.1;"
                >
                    <img
                        t-if="company.logo"
                        t-att-src="image_data_uri(company.logo)"
                        style="max-width: 250px; height:auto; margin-bottom: 3px; display:block; margin-left:auto; margin-right:auto;"
                        alt="Logo"
                    />
                    <t t-if="company.is_company_details_empty">
                        <div style="margin:0; padding:0;">
                            <span
                                t-field="company.partner_id"
                                t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": true}'
                            />
                        </div>
                    </t>
                    <t t-else="">
                        <div style="margin:0; padding:0;">
                            <span t-field="company.company_details" />
                        </div>
                    </t>
                    <t t-if="forced_vat">
                        <div style="margin:0; padding:0;">
                            <t t-esc="company.country_id.vat_label or 'Tax ID'" />:
                            <span t-esc="forced_vat" />
                        </div>
                    </t>
                </div>
            </div>
        </xpath>
        <xpath
            expr="//div[@t-attf-class='footer o_clean_footer o_company_#{company.id}_layout']"
            position="replace"
        >
            <div t-attf-class="footer o_clean_footer o_company_#{company.id}_layout">
                <div class="row">
                    <div class="text-center">
                        <span t-field="company.report_footer" />
                    </div>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
