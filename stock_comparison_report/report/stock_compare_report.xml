<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="stock_compare_report_pdf_document">
        <t t-call="web.external_layout">
            <div class="page" style="font-size: 11px;">
                <div class="label" style="text-align: center">
                    <h2>Stock Comparison Report</h2>
                </div>
                <t t-if="products">
                    <table class="table table-sm o_main_table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th t-esc="location_a_name" />
                                <th t-esc="location_b_name" />
                                <th>Minimum required</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="total_a_qty" t-value="0.0" />
                            <t t-set="total_b_qty" t-value="0.0" />
                            <t t-foreach="products" t-as="p">
                                <tr>
                                    <td><t t-esc="p['product']" /></td>
                                    <td><t t-esc="p['product_name']" /></td>
                                    <td><t t-esc="p['a_qty']" /></td>
                                    <td><t t-esc="p['b_qty']" /></td>
                                    <td><t t-esc="p['min_qty']" /></td>
                                </tr>
                                <t
                                    t-set="total_a_qty"
                                    t-value="total_a_qty + p['a_qty']"
                                />
                                <t
                                    t-set="total_b_qty"
                                    t-value="total_b_qty + p['b_qty']"
                                />
                            </t>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td />
                                <td />
                                <td><t t-esc="total_a_qty" /></td>
                                <td><t t-esc="total_b_qty" /></td>
                                <td />
                            </tr>
                        </tfoot>
                    </table>
                </t>
                <t t-else="">
                    <p>No data to display</p>
                </t>
            </div>

        </t>
    </template>

    <template id="stock_compare_report_pdf">
        <t t-call="web.html_container">
            <t t-call="stock_comparison_report.stock_compare_report_pdf_document" />
        </t>
    </template>
</odoo>
