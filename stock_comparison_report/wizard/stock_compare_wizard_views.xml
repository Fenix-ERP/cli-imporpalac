<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_stock_compare_wizard_form" model="ir.ui.view">
        <field name="name">stock.compare.wizard.form</field>
        <field name="model">stock.compare.wizard</field>
        <field name="arch" type="xml">
            <form string="Compare Stock">
                <group>
                    <field name="location_a_id" />
                    <field name="location_b_id" />
                    <field name="min_qty" />
                </group>
                <footer>
                    <button
                        string="Compare"
                        type="object"
                        name="action_compare"
                        class="btn-primary"
                    />
                    <button string="Cancel" class="btn-secondary" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_stock_compare_wizard" model="ir.actions.act_window">
        <field name="name">Compare Stock</field>
        <field name="res_model">stock.compare.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_stock_compare_wizard_form" />
        <field name="target">new</field>
    </record>

    <menuitem
        id="stock_compare_menu"
        name="Compare Stock"
        parent="stock.menu_warehouse_report"
        action="action_stock_compare_wizard"
    />
</odoo>
